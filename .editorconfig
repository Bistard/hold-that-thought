root = true

# `.editorconfig` maintain consistent coding styles for multiple developers 
# working on the same project across different editors and IDEs. 
# For more information, see http://EditorConfig.org

# default settings for all files
[*]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# YAML spec forbids tabs — must use spaces
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown: trailing spaces can be intentional (line breaks)
[*.md]
trim_trailing_whitespace = false

# Lock files and generated files: do not touch
[{pnpm-lock.yaml,*.lock}]
indent_style = unset
indent_size = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

# Shell scripts: POSIX convention
[*.sh]
indent_style = space
indent_size = 4
