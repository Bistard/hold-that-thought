#!/usr/bin/env bash

MSG=$(cat "$1")

PATTERN="^\[(feat|fix|docs?|refactor|chore|test|style|perf)(\([a-z0-9_/-]+\))?\] .+"

if ! echo "$MSG" | grep -qE "$PATTERN"; then
	echo ""
	echo "❌  Commit message 格式不符合规范"
	echo ""
	echo "   格式要求: [type] description"
	echo "             [type(scope)] description"
	echo ""
	echo "   合法 type: feat  fix  docs  refactor  chore  test  style  perf"
	echo ""
	echo "   示例: "
	echo "     [feat] add login page"
	echo "     [feat(auth)] add login page"
	echo "     [fix(ui)] button click not responding"
	echo "     [docs] update API spec"
	echo "     [refactor(server)] extract auth middleware"
	echo "     [chore] update dependencies"
	echo ""
	echo "   你的 message: $MSG"
	echo ""
	exit 1
fi

exit 0
